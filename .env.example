# Copy to .env and fill in real values. Never commit .env.
DEBUG=false
POSTGRES_USER=app
POSTGRES_PASSWORD=change_me
DATABASE_URL=postgresql+asyncpg://app:change_me@db:5432/fourtwentyone
# Test database — created once in pgAdmin (see README). The pytest suite
# swaps DATABASE_URL → TEST_DATABASE_URL at conftest load time so user
# creation, game seeds, etc. never touch the production DB. Must include
# "test" in the name (safety guard in tests/conftest.py).
TEST_DATABASE_URL=postgresql+asyncpg://app:change_me@localhost:5432/fourtwentyone_test
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REMEMBER_ME_EXPIRE_DAYS=30
APP_URL=https://yourdomain.com
RESET_TOKEN_EXPIRE_MINUTES=60
ANTHROPIC_API_KEY=
RETENTION_DRY_RUN=true
DELETION_GRACE_DAYS=30
SENTRY_DSN=
# Email sender (G68 follow-up). Must be a domain verified with Brevo;
# fall back to a hosted relay address if your domain isn't ready yet.
SENDER_EMAIL=421 Bistro <noreply@yourdomain.com>
# Site owner inbox for contact-form submissions.
CONTACT_EMAIL=
# Google SSO client id (optional).
GOOGLE_CLIENT_ID=
# RGPD policy timings (G68 follow-up). Surfaced via /api/policy-config and
# rendered into the Privacy + Terms pages — change here and the pages
# reflect the new values without a redeploy.
INACTIVE_ACCOUNT_WARNING_YEARS=2
INACTIVE_ACCOUNT_DELETION_DAYS=30
BREACH_NOTIFICATION_HOURS=72
MODERATION_LOG_RETENTION_DAYS=365
# G93: how long the AFK bot will play a human's turn before evicting
# them. Bot stays in-seat until this elapses, then the seat frees up.
# Defaults to 10 minutes. Clamped 5-30 at runtime.
BOT_TAKEOVER_MAX_MINUTES=10
# G93: T-N seconds before eviction, send the AFK player a warning toast.
# Default 120s (2-minute heads-up).
BOT_TAKEOVER_WARNING_SECONDS=120
# Brevo transactional email API key (xkeysib-...). Get one from
# https://app.brevo.com/settings/keys/api → Generate a new API key.
BREVO_API_KEY=
